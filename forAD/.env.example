# Copy this file to .env on the DHCP/AD server and edit values there.
# Do not commit real company paths or account names.

# Folder that the support precheck tool can read.
# Example: \\fileserver\share\dhcp_exports
EXPORT_DESTINATION=

# csv, json, or both
EXPORT_FORMAT=both

# File name prefix. The script appends yyyyMMdd_HHmmss.
EXPORT_PREFIX=dhcp_scopes

# Task Scheduler settings.
TASK_NAME=ICS Support Precheck DHCP Export
TASK_DESCRIPTION=Export DHCP scope ranges for ICS support precheck.

# Monthly schedule. Use 1-31 for TASK_DAY_OF_MONTH.
TASK_DAY_OF_MONTH=1
TASK_TIME=06:00

# Optional. Leave empty to register under the current Windows user.
# If this is set, register_monthly_task.ps1 will ask for the password securely.
TASK_RUN_AS_USER=
