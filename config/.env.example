AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_PARSE_MODEL=google/gemini-2.5-pro
AI_PARSE_FALLBACK_MODEL=
AI_REPLY_MODEL=google/gemini-2.5-flash

# Optional OpenAI direct fallback. Use AI_PROVIDER=openai to enable these.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_REPLY_MODEL=

# Company-specific value. Keep the real group name private in config/.env.
REQUIRED_SECURITY_GROUP=

# DHCP check uses exported local reference files, not PowerShell remoting.
# Point this to a CSV/JSON file or a folder containing monthly DHCP scope exports.
# Supported CSV columns include StartRange and EndRange, as exported from Get-DhcpServerv4Scope.
DHCP_REFERENCE_PATH=
