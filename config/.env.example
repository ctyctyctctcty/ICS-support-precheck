AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_PARSE_MODEL=google/gemini-2.5-pro
AI_PARSE_FALLBACK_MODEL=
AI_REPLY_MODEL=google/gemini-2.5-flash

# Optional OpenAI direct fallback. Use AI_PROVIDER=openai to enable these.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_REPLY_MODEL=

# Company-specific value. Keep the real group name private in config/.env.
REQUIRED_SECURITY_GROUP=

# DHCP check now uses PowerShell remoting to run the lease query on the DHCP server itself.
# - DHCP_SERVER: target server hostname or FQDN, e.g. NKDC2.ad.nkc.co.jp
# - DHCP_QUERY_USERNAME / PASSWORD / DOMAIN: optional alternate credential for remoting.
#   If left blank, the current Windows logon user is used.
DHCP_SERVER=
DHCP_QUERY_USERNAME=
DHCP_QUERY_PASSWORD=
DHCP_QUERY_DOMAIN=
